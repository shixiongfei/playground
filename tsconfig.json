{
  "compilerOptions": {
    "module": "esnext",
    "lib": ["es2021", "DOM", "DOM.Iterable"],
    "target": "es2021",
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.js", "vite-env.d.ts"]
}
